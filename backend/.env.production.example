# ═══════════════════════════════════════════════════════════════════════════
# JAV LABS - Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════

# Server
NODE_ENV=production
PORT=3002

# Database
DATABASE_URL="postgresql://USER:PASSWORD@DB_HOST:5432/DB_NAME"

# JWT Secrets (GENERATE STRONG RANDOM VALUES!)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this-too"

# N8N Integration
N8N_URL=https://n8n-n8n.ak7rlh.easypanel.host
N8N_API_KEY="your-n8n-api-key-here"
N8N_SUPPORT_WEBHOOK_URL="https://n8n-n8n.ak7rlh.easypanel.host/webhook/support-response"

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="JAV LABS <no-reply@javlabs.com>"
EMAIL_ADMIN=admin@javlabs.com

# OAuth (Google)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="https://your-domain.com/api/auth/google/callback"

# Frontend URL
FRONTEND_URL="https://your-domain.com"

# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANT:
# 1. Replace all placeholder values with real production credentials
# 2. Generate strong random secrets for JWT_SECRET and JWT_REFRESH_SECRET
# 3. Update DATABASE_URL with production database connection
# 4. Verify N8N_URL points to your N8N instance
# 5. Set correct GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET
# 6. Update FRONTEND_URL to your production domain
# ═══════════════════════════════════════════════════════════════════════════
