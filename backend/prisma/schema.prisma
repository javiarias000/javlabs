generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(CLIENT)
  company       String?
  phone         String?
  isActive      Boolean        @default(true)
  n8nProjectKey String?
  services      String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  projects      Project[]
  contacts      ContactForm[]
  refreshTokens RefreshToken[]
  tickets       SupportTicket[]        // Tickets creados por este usuario
  assignedTickets SupportTicket[] @relation("AssignedTickets") // Tickets asignados a este agente
  @@map("users")
}

enum Role {
  ADMIN
  AGENT
  CLIENT
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@map("refresh_tokens")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(IN_PROGRESS)
  progress    Int           @default(0)
  startDate   DateTime      @default(now())
  endDate     DateTime?
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  automations Automation[]
  activities  Activity[]
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

model Automation {
  id          String           @id @default(uuid())
  name        String
  description String?
  type        AutomationType
  status      AutomationStatus @default(ACTIVE)
  tasksRun    Int              @default(0)
  timeSaved   Float            @default(0)
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  webhookUrl  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@map("automations")
}

enum AutomationType {
  PROCESS
  API_INTEGRATION
  CHATBOT
  CRM
  REPORT
  WORKFLOW
}

enum AutomationStatus {
  ACTIVE
  PAUSED
  ERROR
  PENDING
}

model Activity {
  id          String   @id @default(uuid())
  description String
  type        String
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  @@map("activities")
}

model ContactForm {
  id        String        @id @default(uuid())
  name      String
  company   String?
  email     String
  phone     String?
  service   String?
  message   String
  status    ContactStatus @default(PENDING)
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())
  @@map("contact_forms")
}

enum ContactStatus {
  PENDING
  READ
  REPLIED
  CLOSED
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  secret    String?
  events    String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  @@map("webhooks")
}

model N8nProject {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("n8n_projects")
}

model SupportTicket {
  id               String              @id @default(uuid())
  userId           String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject          String
  description      String?
  status           TicketStatus        @default(PENDING_HUMAN)
  priority         TicketPriority      @default(MEDIUM)
  assignedAgentId  String?
  assignedAgent    User?               @relation("AssignedTickets", fields: [assignedAgentId], references: [id])
  lastMessageAt    DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  messages         TicketMessage[]
  @@map("support_tickets")
}

enum TicketStatus {
  AUTOMATED        // Bot de IA respondiendo
  HUMAN_TAKEOVER   // Agente humano tomó control
  PENDING_HUMAN    // Cliente solicitó humano, esperando asignación
  COMPLETED        // Ticket resuelto
  CLOSED           // Cerrado sin resolución
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType SenderType
  senderId   String?  // userId si es USER o AGENT, null si es BOT
  content    String
  metadata   Json?    // { confidence: 0.95, sources: [], etc. }
  createdAt  DateTime @default(now())

  @@map("ticket_messages")
}

enum SenderType {
  USER   // Cliente
  BOT    // IA de n8n
  AGENT  // Agente humano de soporte
}
